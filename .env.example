APP_NAME=PulseFi API
APP_VERSION=1.0.0
DEBUG=True

API_V1_PREFIX=/api/v1

# Local development database. Use a limited app role, not the postgres superuser.
DATABASE_URL=postgresql+asyncpg://pulsefi_app:replace_with_local_password@localhost:5432/pulsefi

# Safe test/CI database. Integration tests refuse to run unless the database
# name clearly contains "test" or "ci".
TEST_DATABASE_URL=postgresql+asyncpg://pulsefi_app:replace_with_local_password@localhost:5432/pulsefi_test

# Generate a fresh strong value for each environment. Do not commit real secrets.
SECRET_KEY=replace_with_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Required for encrypted MFA setup secrets. Generate locally with:
# .\venv\Scripts\python.exe -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=replace_with_fernet_key

# Keep False until a real email provider is configured. Development may expose
# dev-only tokens/codes while DEBUG=True; production blocks email-token flows
# when this is False.
EMAIL_DELIVERY_ENABLED=False

BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# MVP rate limiting uses process memory. X-Forwarded-For is trusted only when
# the immediate client IP is listed here, usually a known reverse proxy.
TRUSTED_PROXY_IPS=[]

# Email delivery
# Keep false for local demo token flow.
# Set true only after SMTP settings are configured.
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PulseFi
SMTP_USE_TLS=true
SMTP_USE_SSL=false
FRONTEND_ADMIN_URL=http://localhost:5173
