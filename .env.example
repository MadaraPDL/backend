# PulseFi backend environment example
# Copy this file to .env for local development.
# Never commit real .env files or real secrets.

# App
APP_NAME=PulseFi API
APP_VERSION=0.1.0
DEBUG=True
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/pulsefi
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/pulsefi_test

# Auth/JWT
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace_with_a_long_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - JSON array syntax
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Email delivery
EMAIL_DELIVERY_ENABLED=False
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PulseFi
SMTP_USE_TLS=True
SMTP_USE_SSL=False

# Admin web URL used for invitation, verification, and password reset links
FRONTEND_ADMIN_URL=http://localhost:5173

# Security / encryption - required when DEBUG=False
DATA_ENCRYPTION_KEY=

# Reverse proxy trust list - JSON array syntax
TRUSTED_PROXY_IPS=[]

# Intelligence scheduler
ENABLE_INTELLIGENCE_SCHEDULER=False
INTELLIGENCE_SCHEDULER_INTERVAL_MINUTES=60
